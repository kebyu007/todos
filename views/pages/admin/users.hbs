<section class="page-head">
  <h1>Users</h1>
  <p class="muted">Change roles or remove accounts.</p>
</section>

<div class="card">
  <table class="table">
    <thead>
      <tr><th>User</th><th>Email</th><th>Role</th><th>Timezone</th><th>Actions</th></tr>
    </thead>
    <tbody>
      {{#each users}}
        <tr>
          <td>{{this.username}}{{#if this.isSelf}} <span class="tag">you</span>{{/if}}</td>
          <td>{{this.email}}</td>
          <td>
            <form method="post" action="/admin/users/{{this.id}}" class="inline-form">
              <div 
                class="custom-dropdown" 
                x-data="{ open: false, selectedRole: '{{role}}' }" 
                :class="{ 'custom-dropdown--open': open }" 
                @click.away="open = false"
              >
                <input type="hidden" name="role" :value="selectedRole" value="{{role}}">

                <button type="button" class="custom-dropdown__trigger" @click="open = !open">
                  <span x-text="selectedRole">{{role}}</span>
                  <svg class="custom-dropdown__arrow" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </button>

                <ul class="custom-dropdown__menu" x-show="open" x-cloak>
                  {{#each ../roles}}
                    <li 
                      class="custom-dropdown__option" 
                      :class="{ 'custom-dropdown__option--selected': selectedRole === '{{this}}' }"
                      @click="selectedRole = '{{this}}'; open = false"
                    >
                      {{this}}
                    </li>
                  {{/each}}
                </ul>
              </div>

              <button type="submit" class="btn btn--ghost btn--sm">Save</button>
            </form>
          </td>
          <td>{{this.timezone}}</td>
          <td>
            {{#unless this.isSelf}}
              <form method="post" action="/admin/users/{{this.id}}/delete"
                onsubmit="return confirm('Delete {{this.email}} and all access?')">
                <button type="submit" class="btn btn--danger btn--sm">Delete</button>
              </form>
            {{/unless}}
          </td>
        </tr>
      {{/each}}
    </tbody>
  </table>
</div>
