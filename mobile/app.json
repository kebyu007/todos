{
  "expo": {
    "name": "Todos",
    "slug": "todos-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "todos",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "package": "com.example.todos",
      "googleServicesFile": "./google-services.json",
      "permissions": ["RECEIVE_BOOT_COMPLETED", "SCHEDULE_EXACT_ALARM"]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.todos"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#4f46e5"
        }
      ]
    ],
    "extra": {
      "apiUrl": "http://192.168.1.100:3000",
      "eas": {
        "projectId": ""
      }
    }
  }
}
