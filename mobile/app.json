{
  "expo": {
    "name": "Todos",
    "slug": "todos-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "todos",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "package": "com.example.todos",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.todos"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#4f46e5"
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://kebyu.uz",
      "eas": {
        "projectId": "258b0814-91bd-41f6-8237-f67ded66a479"
      }
    },
    "owner": "kebyu1"
  }
}
