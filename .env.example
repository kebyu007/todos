NODE_ENV=development
PORT=5000

MONGO_URL=mongodb://localhost:27017/todos

# --- Auth: separate secrets for access vs refresh ---
# Generate each with: openssl rand -hex 32
JWT_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Cookies ---
COOKIE_SECURE=false        # true in production (HTTPS only)

# --- Telegram bot (optional) ---
# From @BotFather: /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# --- Seed admins (created or promoted to admin on startup) ---
# Format: email:password,email2:password2
SEED_ADMINS=admin@todos.app:changeme123
